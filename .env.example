# Copy this file to .env.local and fill in your values.
# .env.local is loaded automatically by docker-compose.yml (env_file).

# MongoDB Atlas connection string for the Next.js app (UI / seed data)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/network-mgmt?retryWrites=true&w=majority

# Anthropic API key for the chatbot
ANTHROPIC_API_KEY=sk-ant-...

# MongoDB connection string for the MCP server (can use a read-only user / separate DB user)
MCP_MONGODB_URI=mongodb+srv://mcp-user:password@cluster.mongodb.net/network-mgmt?retryWrites=true&w=majority
